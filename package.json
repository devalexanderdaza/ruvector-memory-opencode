{
  "name": "@ruvector/opencode-memory",
  "version": "0.1.0",
  "description": "OpenCode memory plugin for local-first contextual memory.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check package.json tsconfig.json tsup.config.ts vitest.config.ts biome.json src tests BUILD.md README.md",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "@ruvector/core": "^0.1.30"
  },
  "peerDependenciesMeta": {
    "@ruvector/core": {
      "optional": true
    }
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@ruvector/core": "^0.1.30",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.4",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
